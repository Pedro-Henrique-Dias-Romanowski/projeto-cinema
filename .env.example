DB_ROOT_PASSWORD=rootpassword

DB_USER=cinema_user
DB_PASSWORD=cinema_password

# Nomes dos Bancos de Dados
DB_NAME_AUTENTICACAO=db_autenticacao
DB_NAME_CATALOGO=db_catalogo
DB_NAME_CLIENTES=db_clientes
DB_NAME_SESSOES=db_sessoes

JWT_SECRET=your-secret-key-here-change-this-in-production

# Credenciais do RabbitMQ
RABBITMQ_USER=cinema_rabbitmq
RABBITMQ_PASSWORD=rabbitmq_password

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================

# IMPORTANTE: Para Gmail, você precisa de uma "Senha de App"
# Como gerar:
# 1. Acesse: https://myaccount.google.com/apppasswords
# 2. Selecione "App: Mail" e "Device: Other"
# 3. Copie a senha gerada (16 caracteres)
# 4. Cole abaixo no MAIL_PASSWORD

MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# ============================================
# DISTRIBUTED TRACING (Zipkin)
# ============================================

# URL base do Zipkin para rastreamento distribuído
# Usado por todos os microserviços para enviar traces
SPRING_ZIPKIN_BASE_URL=http://zipkin:9411

# ============================================
# NOTES
# ============================================

# - Não commite o arquivo .env com dados reais
# - Use este .env.example como referência
# - Copie: cp .env.example .env
# - Depois edite o .env com suas credenciais reais
